#!/bin/bash
# Repo-local pre-commit secret scanner. Blocks committing any pattern in
# .github/secret-patterns.txt. install.sh copies this to .git/hooks/pre-commit.
# Editor-agnostic — works regardless of Copilot. Defense-in-depth with GitHub push protection.
#
# False-positive escape valve (do NOT use --no-verify): append `pragma: allowlist secret`
# to the offending line (only on a CONFIRMED non-secret placeholder/example/fixture).

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
PATTERNS="$ROOT/.github/secret-patterns.txt"
[ -f "$PATTERNS" ] || exit 0   # no patterns file -> don't block

STAGED="$(git diff --cached --no-color -U0 | grep '^+' | grep -v '^+++' | grep -v 'pragma: allowlist secret')"
[ -z "$STAGED" ] && exit 0

HITS=""
while IFS= read -r pat; do
  case "$pat" in ''|\#*) continue ;; esac
  if printf '%s' "$STAGED" | grep -E -i -q -- "$pat"; then
    files="$(git diff --cached --name-only -G "$pat" 2>/dev/null | tr '\n' ' ')"
    HITS="$HITS\n  • pattern '$(printf '%s' "$pat" | cut -c1-24)…' in: ${files:-staged content}"
  fi
done < "$PATTERNS"

if [ -n "$HITS" ]; then
  echo "" >&2
  echo "🚫 COMMIT BLOCKED — staged content matches a secret pattern:" >&2
  printf '%b\n' "$HITS" >&2
  echo "" >&2
  echo "Remove the credential (use a secret manager / Actions secret), re-stage, commit again." >&2
  echo "Confirmed false positive? add 'pragma: allowlist secret' to that line (never --no-verify)." >&2
  echo "Patterns: .github/secret-patterns.txt" >&2
  exit 1
fi
exit 0
